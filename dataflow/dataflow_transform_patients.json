{
	"name": "dataflow_transform_patients",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "PatientSource",
						"type": "DatasetReference"
					},
					"name": "patientsSource"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "processedPatients",
						"type": "DatasetReference"
					},
					"name": "sinkPatient"
				}
			],
			"transformations": [
				{
					"name": "maskColumn"
				},
				{
					"name": "selectColumns"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Id as string,",
				"          BIRTHDATE as date,",
				"          DEATHDATE as date,",
				"          PREFIX as string,",
				"          FIRST as string,",
				"          LAST as string,",
				"          SUFFIX as string,",
				"          MAIDEN as string,",
				"          MARITAL as string,",
				"          RACE as string,",
				"          ETHNICITY as string,",
				"          GENDER as string,",
				"          BIRTHPLACE as string,",
				"          ADDRESS as string,",
				"          CITY as string,",
				"          STATE as string,",
				"          COUNTY as string,",
				"          ZIP as short,",
				"          LAT as double,",
				"          LON as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> patientsSource",
				"patientsSource derive(Id = sha2(250, Id),",
				"          BIRTHDATE = toString(year(BIRTHDATE)),",
				"          BIRTHPLACE = '...'+substring(BIRTHPLACE, -2, 2),",
				"          ADDRESS = left(ADDRESS, 3)+'...') ~> maskColumn",
				"maskColumn select(mapColumn(",
				"          Id,",
				"          BIRTHDATE,",
				"          DEATHDATE,",
				"          PREFIX,",
				"          FIRST,",
				"          LAST,",
				"          SUFFIX,",
				"          MAIDEN,",
				"          MARITAL,",
				"          RACE,",
				"          ETHNICITY,",
				"          GENDER,",
				"          BIRTHPLACE,",
				"          ADDRESS,",
				"          CITY,",
				"          STATE,",
				"          COUNTY,",
				"          ZIP",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectColumns",
				"selectColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkPatient"
			]
		}
	}
}
		{
			"name": "[concat(parameters('factoryName'), '/dataflow_transform_Payers')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "payersSource",
								"type": "DatasetReference"
							},
							"name": "payersSource"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "transformedPayer",
								"type": "DatasetReference"
							},
							"name": "ProcessedPayerID"
						}
					],
					"transformations": [
						{
							"name": "payerID"
						}
					],
					"scriptLines": [
						"source(output(",
						"          Id as string,",
						"          NAME as string,",
						"          ADDRESS as string,",
						"          CITY as string,",
						"          STATE_HEADQUARTERED as string,",
						"          ZIP as integer,",
						"          PHONE as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> payersSource",
						"payersSource select(mapColumn(",
						"          Payer_ID = Id,",
						"          NAME,",
						"          ADDRESS,",

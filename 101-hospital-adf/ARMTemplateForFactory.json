		{
			"name": "[concat(parameters('factoryName'), '/ds_transform_encounter')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "dsEncounter",
								"type": "DatasetReference"
							},
							"name": "encountersSource"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "ds_processesed_encounter",
								"type": "DatasetReference"
							},
							"name": "sinkEncounters"
						}
					],
					"transformations": [
						{
							"name": "addOver24HoursColumn"
						},
						{
							"name": "sortPatient"
						},
						{
							"name": "getPreviousStart"
						},
						{
							"name": "addDaysBetweenReadmissionColumn"
						},
						{
							"name": "addReadmissionWithin30DaysColumn"
						},
						{
							"name": "selectColumnsForSink"
						}
					],
					"scriptLines": [
						"source(output(",
						"          Id as string,",
						"          START as timestamp 'yyyy-MM-dd\\'T\\'HH:mm:ss\\'Z\\'',",
						"          STOP as timestamp 'yyyy-MM-dd\\'T\\'HH:mm:ss\\'Z\\'',",
						"          PATIENT as string,",
